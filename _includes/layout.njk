<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title | default("Le Foutoir Connecté") }}</title>
  <meta name="description" content="{{ description | default("Le guide d'architecture de votre domotique locale.") | escape }}">
  <meta name="max-image-preview" content="large">

  <!-- Open Graph / Facebook / LinkedIn -->
  <meta property="og:type" content="article">
  <meta property="og:title" content="{{ title | default("Le Foutoir Connecté") | escape }}">
  <meta property="og:description" content="{{ description | default("Le guide d'architecture de votre domotique locale.") | escape }}">
  <meta property="og:url" content="https://foutoirconnecte.com{{ page.url }}">
  <meta property="og:image" content="https://foutoirconnecte.com{{ image | default('/images/default-social.png') }}">

  <!-- Twitter / X -->
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="{{ title | default("Le Foutoir Connecté") | escape }}">
  <meta name="twitter:description" content="{{ description | default("Le guide d'architecture de votre domotique locale.") | escape }}">
  <meta name="twitter:image" content="https://foutoirconnecte.com{{ image | default('/images/default-social.png') }}">

  <link rel="icon" href="/images/favicon.webp" type="image/webp">

  <style>
    :root {
      --primary-color: #10b981; 
      --primary-dark: #059669;
      --text-main: #334155;
      --text-muted: #64748b;
      --bg-body: #f1f5f9;
      --bg-card: #ffffff;
      --header-bg: #1e293b; /* Bleu Nuit sobre mais coloré */
    }
    body { 
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Oxygen, Ubuntu, Cantarell, sans-serif; 
      line-height: 1.7; 
      background-color: var(--bg-body);
      color: var(--text-main);
      margin: 0; 
      padding: 0; 
      display: flex;
      flex-direction: column;
      min-height: 100vh;
    }
    .container {
      flex: 1;
      max-width: 1100px;
      margin: 0 auto;
      padding: 0 20px 60px 20px;
      width: 100%;
      box-sizing: border-box;
    }
    h1, h2, h3 { 
      color: #0f172a; 
      line-height: 1.3;
      margin-top: 1.8em;
    }
    h1 { margin-top: 0; }
    a { 
      color: var(--primary-color); 
      text-decoration: none; 
      transition: color 0.2s ease-in-out;
    }
    a:hover { 
      color: var(--primary-dark);
      text-decoration: underline; 
    }
    
    /* Header & Navbar */
    .site-header { 
      background: var(--header-bg);
      color: #f8fafc;
      margin-bottom: 40px; 
      padding: 20px 20px; 
      box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1);
      border-bottom: 4px solid var(--primary-color);
    }
    .header-content {
      max-width: 1100px;
      margin: 0 auto;
      display: flex;
      justify-content: space-between;
      align-items: center;
      flex-wrap: wrap;
      gap: 20px;
    }
    .logo-area h1 {
      margin: 0 0 5px 0;
      font-size: 2rem;
      letter-spacing: -0.02em;
      color: #ffffff;
    }
    .logo-area h1 a { color: #ffffff; text-decoration: none; }
    .logo-area h1 a:hover { text-decoration: none; }
    .logo-area p { margin: 0; color: #94a3b8; font-size: 0.95rem; }
    
    .header-nav {
      display: flex;
      gap: 20px;
      align-items: center;
    }
    .header-nav a {
      color: #e2e8f0;
      font-weight: 500;
      font-size: 0.95rem;
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }
    .header-nav a:hover {
      color: var(--primary-color);
      text-decoration: none;
    }

    .search-icon {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 40px;
      height: 40px;
      background: rgba(255,255,255,0.1);
      border-radius: 50%;
      color: #ffffff;
      transition: background 0.2s;
    }
    .search-icon:hover {
      background: rgba(255,255,255,0.2);
    }

    main {
      background: var(--bg-card);
      padding: 50px;
      border-radius: 16px;
      box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.05);
    }
    
    /* Articles Grid used in multiple places */
    .articles-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(300px, 1fr)); /* Aim for 3 columns by default */
      gap: 35px;
      margin-top: 40px;
    }
    @media (max-width: 992px) { /* For screens smaller than large desktops */
      .articles-grid {
        grid-template-columns: repeat(2, minmax(300px, 1fr)); /* 2 columns */
      }
    }
    @media (max-width: 768px) { /* For tablets and smaller */
      .articles-grid {
        grid-template-columns: repeat(1, minmax(300px, 1fr)); /* 1 column */
      }
    }
    .article-card {
      background: var(--bg-card);
      border-radius: 12px;
      overflow: hidden;
      border: 1px solid #e2e8f0;
      box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05);
      transition: transform 0.2s, box-shadow 0.2s;
      display: flex;
      flex-direction: column;
    }
    .article-card:hover {
      transform: translateY(-5px);
      box-shadow: 0 15px 25px -5px rgba(0,0,0,0.1);
      border-color: #cbd5e1;
    }
    .article-card-img { width: 100%; height: 200px; object-fit: cover; }
    .article-card-content { padding: 25px; flex: 1; display: flex; flex-direction: column; }
    .article-card-content h3 { margin: 0 0 15px 0; font-size: 1.35rem; line-height: 1.4; }
    .article-card-meta {
      font-size: 0.85rem; color: var(--text-muted); margin-bottom: 15px;
      display: flex; align-items: center; gap: 12px; text-transform: uppercase; font-weight: 500;
    }
    .article-card-meta svg { width: 14px; height: 14px; fill: currentColor; }
    .article-card-summary { font-size: 0.95rem; color: #475569; margin-top: auto; line-height: 1.6; }

    /* Footer */
    .site-footer {
      text-align: center;
      padding: 30px 20px;
      background: var(--header-bg);
      color: #94a3b8;
      font-size: 0.9rem;
      margin-top: auto;
    }
    .site-footer a { color: #e2e8f0; margin: 0 10px; }
    
    @media (max-width: 768px) {
      .header-content { flex-direction: column; text-align: center; }
      .header-nav { flex-wrap: wrap; justify-content: center; }
      main { padding: 30px 20px; }
    }
  </style>
  <script data-goatcounter="https://foutoirconnecte.goatcounter.com/count" async src="//gc.zgo.at/count.js"></script>
</body>
</html>
