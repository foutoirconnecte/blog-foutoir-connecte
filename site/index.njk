---
layout: layout.njk
title: Accueil - Le Foutoir Connecté
---

<style>
.hero-banner {
  width: 100%;
  height: 380px;
  border-radius: 16px;
  object-fit: cover;
  margin-bottom: 25px; /* Réduit l'espace */
  box-shadow: 0 10px 15px -3px rgba(0,0,0,0.1);
}
.intro-text {
  max-width: 850px;
  margin: 0 auto 25px auto; /* Réduit l'espace */
  font-size: 1.15rem;
  line-height: 1.8;
}
.intro-text h2 { font-size: 2rem; margin-top: 1.5em; }
.intro-text h3 { font-size: 1.8rem; margin-top: 1em; }
</style>

<img src="/images/banner.webp" class="hero-banner" alt="Maison connectée moderne">

<div class="intro-text" data-pagefind-ignore>
  <h2>Votre maison est devenue un enfer numérique ? </h2>
</div>


<div class="articles-grid">
{% for post in collections.article | reverse %}
  <div class="article-card">
    {% if post.data.image %}
    <a href="{{ post.url }}"><img src="{{ post.data.image }}" alt="{{ post.data.title }}" class="article-card-img"></a>
    {% endif %}
    <div class="article-card-content">
      <div style="margin-bottom: 10px; display:flex; gap: 8px; flex-wrap: wrap;">
        {% for pt in post.data.tags %}
          {% if pt != "post" and pt != "article" %}
          <span style="font-size:0.75rem; background:var(--primary-color); color:#fff; padding:2px 8px; border-radius:12px; font-weight:bold; text-transform:uppercase; white-space: nowrap;">{{ pt }}</span>
          {% endif %}
        {% endfor %}
      </div>
      <h3 style="margin-top:0; margin-bottom: 10px;"><a href="{{ post.url }}">{{ post.data.title }}</a></h3>
      <div class="article-card-meta" style="margin-bottom: 10px;">
        <span style="display:flex; align-items:center; gap:5px;"><svg viewBox="0 0 24 24"><path d="M19 4h-1V2h-2v2H8V2H6v2H5c-1.11 0-1.99.9-1.99 2L3 20a2 2 0 0 0 2 2h14c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 16H5V10h14v10zm0-12H5V6h14v2z"/></svg> {{ post.data.date | readableDate }}</span>
        <span style="display:flex; align-items:center; gap:5px;"><svg viewBox="0 0 24 24"><path d="M11.99 2C6.47 2 2 6.48 2 12s4.47 10 9.99 10C17.52 22 22 17.52 22 12S17.52 2 11.99 2zM12 20c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8zm.5-13H11v6l5.25 3.15.75-1.23-4.5-2.67z"/></svg> {{ post.content | readingTime }} min</span>
      </div>
      {% if post.data.summary %}
      <div class="article-card-summary" style="margin-top: 0;">{{ post.data.summary }}</div>
      {% endif %}
    </div>
  </div>
{% endfor %}
</div>
